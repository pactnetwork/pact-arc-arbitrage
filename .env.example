# === Pact × Agora — env template ===
# Copy this file to .env at the repo root, fill in the three private keys.

# --- Wallets (32-byte hex private keys, 0x-prefixed) ---
# The demo runs with ONE wallet acting as all three roles by default — just set
# AUTHORITY_PRIVATE_KEY=SETTLER_PRIVATE_KEY=AGENT_PRIVATE_KEY to the same value.
# For a production-shaped run, use three distinct EOAs.
AUTHORITY_PRIVATE_KEY=0x...
SETTLER_PRIVATE_KEY=0x...
AGENT_PRIVATE_KEY=0x...

# Optional split: override the burn-side wallet (defaults to AGENT_PRIVATE_KEY)
# ARC_PRIVATE_KEY=0x...
# Optional split: override the mint-side wallet on Base (defaults to ARC_PRIVATE_KEY)
# BASE_PRIVATE_KEY=0x...

# --- Arc Testnet ---
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_USDC=0x3600000000000000000000000000000000000000

# --- Pact protocol contracts on Arc (deployed Phase-07b, 2026-05-19) ---
PACT_REGISTRY=0x60e51f2c8c162ec13c7c7234fc9490936127f01b
PACT_POOL=0xc5d4c573828e998695b6bd5577947bc77a8f7f97
PACT_SETTLER=0xccf30140d74cc0d384800501506d50fe622ae963

# --- Base Sepolia (CCTP destination) ---
BASE_RPC_URL=https://sepolia.base.org
BASE_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# --- CCTP v2 (same CREATE2 address on both chains) ---
CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
CCTP_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
ARC_SOURCE_DOMAIN=26
BASE_SEPOLIA_DEST_DOMAIN=6

# --- Iris attestation API ---
IRIS_API_BASE=https://iris-api-sandbox.circle.com
IRIS_POLL_INTERVAL_MS=5000
# Default 30 min. Set to 5 to force the BridgeTimeout breach demo path.
IRIS_POLL_TIMEOUT_S=1800

# --- Demo parameters ---
DEMO_SLUG=arc-cctp-base
DEMO_PRINCIPAL_USDC=1000000       # 1.00 USDC bridged
DEMO_PREMIUM_USDC=50000           # 0.05 USDC premium
DEMO_TOPUP_USDC=2000000           # 2.00 USDC pool headroom
DEMO_BREACH_REFUND_USDC=1050000   # principal + premium on breach
DEMO_SLA_BPS=50                   # 0.50% slippage tolerance
DEMO_SLA_LATENCY_MS=900000        # 15 min — matches Arc-outbound CCTP standard window

# --- Prices (mock | coingecko) ---
PRICE_SOURCE=mock
